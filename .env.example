# ╔══════════════════════════════════════════════════════════════╗
# ║  中泰词典 · 环境变量模板（无密钥，可提交；复制为 .env.local 填真实值） ║
# ╚══════════════════════════════════════════════════════════════╝
# 用法：
#   本地开发：复制本文件为 .env.local 并填入真实值（.env.local 已被 gitignore）
#   Vercel 部署：在 Dashboard → Settings → Environment Variables → Import from .env
#                直接上传填好的 .env.local；或运行 scripts/import-env.sh

# ===== Supabase（前端可读，必须 NEXT_PUBLIC_ 前缀） =====
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# ===== Supabase 服务端密钥（仅 API Route 使用，绝不暴露前端） =====
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# ===== 站点地址（OAuth 回调 / Magic Link / 邮件链接） =====
NEXT_PUBLIC_SITE_URL=https://YOUR-DOMAIN.vercel.app

# ===== Brevo 邮件服务（OTP 验证码 + 学习提醒） =====
BREVO_API_KEY=YOUR-BREVO-API-KEY
BREVO_SENDER_EMAIL=noreply@yourdomain.com
BREVO_SENDER_NAME=中泰词典

# ===== 泰语分词微服务（PyThaiNLP newmm，可选） =====
# 部署 services/thai-segment/ 后填写其公网地址；留空则走服务端 JS 分词器兜底
THAI_SEGMENT_SERVICE_URL=https://your-thai-segment-service.com/segment

# ===== 系统默认 AI API（服务端 only；实际配置在 system_config 表） =====
# 系统内置 AI API 读取 system_config 表中的三行：
#   SYSTEM_AI_API_KEY    = sk-...
#   SYSTEM_AI_BASE_URL   = https://api.xxx.com/v1
#   SYSTEM_AI_MODEL      = model-name
# 以下环境变量已弃用，保留仅供旧迁移参考；请勿依赖。
# SYSTEM_AI_CONFIG_KEY=ai_system_api
